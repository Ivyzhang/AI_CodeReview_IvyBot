GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY_HOST_PATH=/absolute/path/to/github-app.pem
GITHUB_WEBHOOK_SECRET=replace-with-a-random-secret

LLM_BASE_URL=https://your-llm-service.example.com/v1
LLM_API_KEY=replace-with-model-key
LLM_MODEL=replace-with-model-name

INSTALLATION_DAILY_TASK_LIMIT=200
